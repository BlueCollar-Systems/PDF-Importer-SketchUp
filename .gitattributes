# Normalize line endings: store text as LF in the repo.
# CRLF/LF churn previously caused false "drift" reports between the LF
# canonical core and CRLF checkouts. Keep repo content LF.
* text=auto eol=lf

*.rb   text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Binary assets - never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.rbz binary
*.skp binary
